datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(uuid())
  username      String?         @unique
  email         String          @unique
  password      String
  role          String          @default("BUYER") // BUYER, SELLER, FOUNDER, CEO_MD, CHAIRMAN, ADMIN
  fullName      String?
  phone         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  orders        Order[]         @relation("BuyerOrders")
  sellerProfile Seller?
  reviews       Review[]
}

model Seller {
  id                String          @id @default(uuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName         String
  storeDescription  String?
  gstNumber         String?
  panNumber         String?
  bankAccountNo     String?
  bankIfsc          String?
  bankAccountName   String?
  upiId             String?
  commissionRate    Float           @default(10.0)
  status            String          @default("PENDING") // PENDING, ACTIVE, SUSPENDED
  logoUrl           String?
  bannerUrl         String?
  businessType      String?
  city              String?
  state             String?
  pincode           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  emailVerified     Boolean         @default(false)
  otpCode           String?
  otpExpiresAt      DateTime?
  otpResendCount    Int             @default(0)
  lastOtpSentAt     DateTime?
  verificationStatus String         @default("PENDING_VERIFICATION")
  products          Product[]
  orders            Order[]         @relation("SellerOrders")
  wallet            VendorWallet?
  payouts           PayoutRequest[]
  commissions       Commission[]
  pickupAddress     PickupAddress?
  shipments         Shipment[]
  subscriptions     Subscription[]
  coupons           Coupon[]
  settings          SellerSettings?
}

model Product {
  id                   String      @id @default(uuid())
  sellerId             String
  seller               Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title                String
  price                Float
  comparePrice         Float?
  stock                Int         @default(0)
  category             String
  shortDescription     String?
  description          String?
  sku                  String?
  barcode              String?
  status               String      @default("draft")
  images               String?
  variants             String?
  tags                 String?
  weight               Float?
  weightUnit           String      @default("kg")
  dimensionLength      Float?
  dimensionWidth       Float?
  dimensionHeight      Float?
  packageType          String      @default("box")
  shippingClass        String      @default("standard")
  fragile              Boolean     @default(false)
  dangerousGoods       Boolean     @default(false)
  countryOfOrigin      String      @default("India")
  hsnCode              String?
  estimatedPackingTime Int         @default(24)
  createdAt            DateTime    @default(now())
  orderItems           OrderItem[]
  reviews              Review[]
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  buyerId         String
  buyer           User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId        String?
  seller          Seller?       @relation("SellerOrders", fields: [sellerId], references: [id])
  status          String        @default("PENDING")
  paymentStatus   String        @default("PENDING")
  paymentMethod   String?
  subtotal        Float
  discountAmount  Float         @default(0)
  shippingAmount  Float         @default(0)
  taxAmount       Float         @default(0)
  totalAmount     Float
  isCod           Boolean       @default(false)
  shippingAddress String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           OrderItem[]
  payments        Payment[]
  commission      Commission?
  shipments       Shipment[]
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  title       String
  price       Float
  quantity    Int
  total       Float
  shipmentId  String?
  shipment    Shipment? @relation(fields: [shipmentId], references: [id])
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gateway           String        @default("RAZORPAY")
  amount            Float
  status            String        @default("PENDING")
  method            String?
  gatewayLogs       String?
  webhookVerified   Boolean       @default(false)
  transactionReference String?     @unique
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Commission {
  id                String      @id @default(uuid())
  orderId           String      @unique
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId          String
  seller            Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderAmount       Float
  commissionRate    Float
  commissionAmount  Float
  sellerPayout      Float
  status            String      @default("PENDING")
  createdAt         DateTime    @default(now())
}

model VendorWallet {
  id                String              @id @default(uuid())
  sellerId          String              @unique
  seller            Seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  balance           Float               @default(0.0)
  pendingEarnings   Float               @default(0.0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  transactions      WalletTransaction[]
}

model WalletTransaction {
  id            String       @id @default(uuid())
  walletId      String
  wallet        VendorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount        Float
  type          String
  description   String
  createdAt     DateTime     @default(now())
}

model PayoutRequest {
  id            String       @id @default(uuid())
  sellerId      String
  seller        Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  amount        Float
  status        String       @default("PENDING")
  paymentMethod String
  bankDetails   String?
  upiId         String?
  transactionId String?
  notes         String?
  requestedAt   DateTime     @default(now())
  processedAt   DateTime?
}

model GlobalSettings {
  id                      String   @id @default("settings")
  defaultCommissionRate   Float    @default(10.0)
  categoryCommissions     String
  settlementDelayDays     Int      @default(7)
  parentCompanyLogoUrl    String?
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  orderId     String?
  subject     String
  description String
  type        String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminNotification {
  id          String   @id @default(uuid())
  title       String
  message     String
  type        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model PickupAddress {
  id                 String   @id @default(uuid())
  sellerId           String   @unique
  seller             Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  storeName          String
  contactName        String
  phone              String
  email              String
  addressLine1       String
  addressLine2       String?
  city               String
  state              String
  pincode            String
  country            String   @default("India")
  pickupLocationId   String?
  verificationStatus String   @default("PENDING")
  latitude           Float?
  longitude          Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CourierPartner {
  id                 String     @id @default(uuid())
  name               String     @unique
  code               String     @unique
  isActive           Boolean    @default(true)
  baseRatePrepaid    Float      @default(40.0)
  baseRateCOD        Float      @default(60.0)
  averageDeliveryDays Int       @default(4)
  shipments          Shipment[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Shipment {
  id               String          @id @default(uuid())
  shipmentNumber   String          @unique
  orderId          String
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId         String
  seller           Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  courierPartnerId String?
  courierPartner   CourierPartner? @relation(fields: [courierPartnerId], references: [id])
  status           String          @default("PENDING")
  awbNumber        String?         @unique
  trackingNumber   String?         @unique
  trackingLink     String?
  labelUrl         String?
  codAmount        Float           @default(0.0)
  shippingCost     Float           @default(0.0)
  weight           Float           @default(0.5)
  dispatchDate     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            OrderItem[]
  trackingUpdates  TrackingUpdate[]
  invoice          Invoice?
}

model TrackingUpdate {
  id         String   @id @default(uuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status     String
  location   String?
  message    String
  timestamp  DateTime @default(now())
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  shipmentId    String   @unique
  shipment      Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  invoiceDate   DateTime @default(now())
  subtotal      Float
  taxAmount     Float
  totalAmount   Float
  pdfUrl        String?
  createdAt     DateTime @default(now())
}

model NewsletterSubscription {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Review {
  id             String   @id @default(uuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating         Int
  comment        String
  status         String   @default("pending")
  sellerResponse String?
  createdAt      DateTime @default(now())
}

model Lead {
  id           String    @id @default(uuid())
  name         String
  email        String
  phone        String
  company      String?
  source       String    @default("other")
  status       String    @default("new")
  priority     String    @default("medium")
  assignedTo   String?
  followUpDate DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SubscriptionPlan {
  id            String         @id @default(uuid())
  name          String
  description   String?
  price         Float
  features      String
  durationDays  Int            @default(30)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id           String           @id @default(uuid())
  sellerId     String
  seller       Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  planId       String
  plan         SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  billingCycle String           @default("monthly")
  status       String           @default("active")
  startDate    DateTime         @default(now())
  endDate      DateTime
  amount       Float
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Coupon {
  id            String   @id @default(uuid())
  sellerId      String
  seller        Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  code          String   @unique
  discountType  String
  discountValue Float
  minSpend      Float    @default(0.0)
  expiryDate    String
  status        String   @default("active")
  usageCount    Int      @default(0)
  totalSavings  Float    @default(0.0)
  createdAt     DateTime @default(now())
}

model SellerSettings {
  id                  String   @id @default(uuid())
  sellerId            String   @unique
  seller              Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  notificationPrefs   String
  twoFaEnabled        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model OTP {
  id          String   @id @default(uuid())
  email       String   @unique
  otpCode     String
  expiresAt   DateTime
  attempts    Int      @default(0)
  lockedUntil DateTime?
  createdAt   DateTime @default(now())
}

model PincodeServiceability {
  id              String   @id @default(uuid())
  pincode         String   @unique
  city            String
  state           String
  isMetro         Boolean  @default(false)
  allowCod        Boolean  @default(true)
  deliveryDays    Int      @default(4)
  createdAt       DateTime @default(now())
}

model ShippingAuditLog {
  id          String   @id @default(uuid())
  shipmentId  String?
  action      String
  performedBy String
  role        String
  details     String?
  createdAt   DateTime @default(now())
}